# ── Database ──────────────────────────────────────────
# Get from: mongodb.com/atlas
# Steps: Sign up free → Create cluster M0 → Connect → Drivers → copy string
# Replace <password> with your real Atlas password
MONGO_URI=mongodb+srv://youruser:yourpassword@cluster0.xxxxx.mongodb.net/tasknas?retryWrites=true&w=majority
# ── Auth ──────────────────────────────────────────────
# Make up any long random string — keep it secret
JWT_SECRET=task-nas_AI_2026

# ── AI ────────────────────────────────────────────────
# Get from: aistudio.google.com/app/apikey 
# Steps: Sign in with Google → Create API Key → copy it
GEMINI_API_KEY=AIzaSy_YOUR_KEY_HERE

# ── Server ────────────────────────────────────────────
PORT=5000
